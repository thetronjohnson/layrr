[Unit]
Description=Layrr Dashboard (Next.js)
After=network.target layrr-server.service

[Service]
Type=simple
User=layrr
WorkingDirectory=/opt/layrr/packages/app
ExecStart=/usr/bin/npx next start -p 3000 -H 0.0.0.0
Restart=always
RestartSec=5
EnvironmentFile=/opt/layrr/.env
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0

[Install]
WantedBy=multi-user.target
